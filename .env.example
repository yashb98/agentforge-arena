# AgentForge Arena — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ============================================================
# Application
# ============================================================
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_JWT_SECRET=change-me-in-production-use-openssl-rand-base64-32
APP_CORS_ORIGINS=["http://localhost:3000"]

# ============================================================
# Database (PostgreSQL)
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentforge
DB_USER=agentforge
DB_PASSWORD=agentforge
DB_POOL_SIZE=20

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================================
# LLM Providers (via LiteLLM)
# ============================================================
LLM_LITELLM_PROXY_URL=http://localhost:4000
LLM_DEFAULT_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS_DEFAULT=8192
LLM_TIMEOUT_SECONDS=300
LLM_BUDGET_PER_TOURNAMENT_USD=500.0

# API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ============================================================
# Langfuse (Tracing)
# ============================================================
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3001

# ============================================================
# Object Storage (MinIO)
# ============================================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_ARTIFACTS=arena-artifacts
S3_BUCKET_REPLAYS=arena-replays

# ============================================================
# Sandbox (Docker)
# ============================================================
SANDBOX_DEFAULT_MEMORY=4g
SANDBOX_DEFAULT_CPUS=2
SANDBOX_WORKSPACE_BASE=/arena
SANDBOX_PRE_WARM=true

# ============================================================
# GitHub (for Research Agent)
# ============================================================
# GITHUB_TOKEN=ghp_...
